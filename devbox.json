{
  "$schema":  "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "hugo@0.161.1",
    "dart-sass@1.99.0",
    "nodejs@22",
    "lefthook@latest"
  ],
  "shell": {
    "init_hook": [
      "[ ! -f package.json ] || [ -d node_modules ] || npm install --silent",
      "[ ! -d .git ] || lefthook install -f >/dev/null"
    ],
    "scripts": {
      "build":     ["hugo --minify"],
      "serve":     ["hugo server -D --disableFastRender"],
      "typecheck": ["npx tsc --noEmit"]
    }
  }
}
